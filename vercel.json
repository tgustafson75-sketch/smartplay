{
  "version": 2,
  "outputDirectory": "dist",
  "builds": [
    {
      "src": "api/*.ts",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    }
  ],
  "routes": [
    { "src": "/api/brain",      "dest": "/api/brain.ts" },
    { "src": "/api/voice",      "dest": "/api/voice.ts" },
    { "src": "/api/transcribe", "dest": "/api/transcribe.ts" },
    { "src": "/api/vision",     "dest": "/api/vision.ts" },
    { "src": "/api/preround",     "dest": "/api/preround.ts" },
    { "src": "/api/smartmotion",  "dest": "/api/smartmotion.ts" },
    { "src": "/api/kevin",        "dest": "/api/kevin.ts" },
    { "src": "/api/briefing",     "dest": "/api/briefing.ts" },
    { "src": "/api/recap",        "dest": "/api/recap.ts" },
    { "src": "/api/course-proxy", "dest": "/api/course-proxy.ts" },
    { "src": "/api/cage-review",  "dest": "/api/cage-review.ts" },
    { "src": "/api/voice-intent", "dest": "/api/voice-intent.ts" },
    { "src": "/api/parse-shot",   "dest": "/api/parse-shot.ts" },
    { "src": "/api/health",          "dest": "/api/health.ts" },
    { "src": "/api/course-geometry", "dest": "/api/course-geometry.ts" },
    { "src": "/api/weather",         "dest": "/api/weather.ts" },
    { "src": "/api/course-content",  "dest": "/api/course-content.ts" },
    { "src": "/api/lie-analysis",    "dest": "/api/lie-analysis.ts" },
    { "src": "/api/swing-analysis",  "dest": "/api/swing-analysis.ts" },
    { "src": "/api/image-edit",      "dest": "/api/image-edit.ts" },
    { "src": "/api/cv-scoring",      "dest": "/api/cv-scoring.ts" },
    { "src": "/api/kevin/coach",     "dest": "/api/cage-coach.ts" },
    { "src": "/api/context-synthesis", "dest": "/api/context-synthesis.ts" },
    { "src": "/api/club-recognition",  "dest": "/api/club-recognition.ts" },
    { "src": "/api/space-scan",        "dest": "/api/space-scan.ts" },
    { "src": "/api/tutorial-analysis", "dest": "/api/tutorial-analysis.ts" },
    { "src": "/api/golfbert-proxy",    "dest": "/api/golfbert-proxy.ts" },
    { "src": "/api/pose-analysis",     "dest": "/api/pose-analysis.ts" },
    { "src": "/api/acoustic-detect",   "dest": "/api/acoustic-detect.ts" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
