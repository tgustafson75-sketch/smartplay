{
  "name": "smartplaycaddie",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "build": "expo export --platform web",
    "vercel-build": "expo export --platform web",
    "generate:greetings": "node scripts/generate-kevin-greetings.mjs",
    "sim": "tsx scripts/simulations/run-sim.ts",
    "sim:round": "tsx scripts/simulations/synthetic-round.ts",
    "kevin": "tsx --env-file=.env.local scripts/generate-caddie.ts kevin",
    "caddie": "tsx --env-file=.env.local scripts/generate-caddie.ts",
    "ios:build:preview": "eas build --profile preview --platform ios",
    "ios:build:production": "eas build --profile production --platform ios",
    "ios:submit": "eas submit --profile production --platform ios --latest",
    "ios:ship": "eas build --profile production --platform ios --auto-submit-with-profile production",
    "ota:preview": "eas update --branch preview",
    "ota:production": "eas update --branch production",
    "android:build:preview": "eas build --profile preview --platform android",
    "android:build:production": "eas build --profile production --platform android"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.6.3",
    "@react-navigation/native": "^7.1.8",
    "@react-three/fiber": "^9.6.1",
    "@sentry/react-native": "~7.2.0",
    "@shopify/react-native-skia": "2.2.12",
    "expo": "~54.0.33",
    "expo-asset": "~12.0.13",
    "expo-av": "~16.0.8",
    "expo-battery": "~10.0.8",
    "expo-blur": "~15.0.8",
    "expo-build-properties": "~1.0.10",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-gl": "~16.0.10",
    "expo-haptics": "~15.0.8",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.8",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-print": "~15.0.8",
    "expo-router": "~6.0.23",
    "expo-screen-orientation": "~9.0.9",
    "expo-sensors": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-task-manager": "~14.0.9",
    "expo-three": "^8.0.0",
    "expo-updates": "~29.0.17",
    "expo-video-thumbnails": "~10.0.8",
    "expo-web-browser": "~15.0.10",
    "formidable": "^3.5.4",
    "i18next": "^26.2.0",
    "openai": "^6.34.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^17.0.8",
