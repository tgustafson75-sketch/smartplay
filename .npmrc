# 2026-05-22 — Vercel build was failing on strict peer-dep checks.
# expo-three@8.0.0 declares peer three@^0.166; project runs three@0.184
# (chosen by expo's stable matrix for SDK 54). The three.js 0.184 ships
# the same runtime API expo-three 8.0.0 uses; the peer version range
# is just stale.
#
# This file makes ALL npm installs (including Vercel's build-time
# install) accept the version mismatch instead of bailing out. Without
# it, Vercel's install errors with ERESOLVE → build never runs →
# every route returns 404.
legacy-peer-deps=true
