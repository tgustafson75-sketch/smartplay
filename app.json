{
  "expo": {
    "name": "SmartPlay Caddie",
    "slug": "smartplay-caddie",
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "smartplay",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.smartplaycaddie.app",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "SmartPlay Caddie uses the microphone to listen for your voice commands.",
        "NSCameraUsageDescription": "SmartPlay Caddie uses the camera to record and analyze your swing in the practice cage.",
        "NSLocationWhenInUseUsageDescription": "SmartPlay Caddie uses your location to find nearby golf courses and track your round.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "SmartPlay Caddie tracks your round in the background so hole transitions, shot tracking, and yardages keep working when your phone is in your pocket.",
        "NSPhotoLibraryUsageDescription": "SmartPlay Caddie saves your hero moments to your photo library.",
        "UIBackgroundModes": [
          "audio",
          "location"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "buildNumber": "3"
    },
    "android": {
      "package": "com.smartplaycaddie.app",
      "adaptiveIcon": {
        "backgroundColor": "#060f09",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_BACKGROUND_LOCATION",
        "android.permission.VIBRATE",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.FOREGROUND_SERVICE_LOCATION",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.health.READ_STEPS",
        "android.permission.health.READ_DISTANCE",
        "android.permission.health.READ_HEART_RATE",
        "android.permission.health.READ_EXERCISE",
        "android.permission.health.READ_ACTIVE_CALORIES_BURNED"
      ]
    },
    "web": {
      "output": "server",
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-screen-orientation",
      "expo-camera",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "SmartPlay Caddie tracks your round in the background so hole transitions, shot tracking, and yardages keep working when your phone is in your pocket.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 320,
          "resizeMode": "contain",
          "backgroundColor": "#060f09"
        }
      ],
      [
        "@sentry/react-native",
        {
          "uploadSourceMaps": false,
          "organization": "smartplay",
          "project": "smartplay-caddie-mobile"
        }
      ],
      "react-native-health-connect",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 29,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      "./plugins/withMetaWearablesDAT.js",
      "./plugins/withMediaPipePose.js",
      "./plugins/withBluetoothMediaButton.js",
      "./plugins/withPrebuildSafetyCheck.js",
      "expo-asset",
      "expo-localization"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "60b7ee0e-0165-4971-a9c8-219960fed645"
      }
    },
    "owner": "tgustafson76",
    "runtimeVersion": "1.0.0",
    "updates": {
      "url": "https://u.expo.dev/60b7ee0e-0165-4971-a9c8-219960fed645",
      "fallbackToCacheTimeout": 10000
    }
  }
}
