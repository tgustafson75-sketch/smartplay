# Required
ANTHROPIC_API_KEY=your_anthropic_key
OPENAI_API_KEY=your_openai_key
DEEPGRAM_API_KEY=your_deepgram_key   # free tier: 12k min/month — deepgram.com/signup

# The Vercel deployment that Pipecat calls back for tool execution
VERCEL_API_URL=https://smartplaycaddie.vercel.app

# Session auth — shared secret between React Native client and this server
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=your_session_secret_here

# Optional — override LLM model
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=onyx
