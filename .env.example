# D-ID API pipeline for caddie video generation.
# Copy these into .env.local (which IS gitignored — your real values
# never leave your machine). The script scripts/generate-caddie.ts
# reads these via --env-file=.env.local at runtime.

# ── REQUIRED ─────────────────────────────────────────────────────────
# D-ID dashboard → API Keys → copy the key
D_ID_API_KEY=your_did_api_key_here

# ── OPTIONAL per caddie ──────────────────────────────────────────────
# D-ID Studio → Presenters → click your custom Kevin → copy presenter_id.
# When unset, the script falls back to a STOCK source_url (Alice) so
# you can validate the pipeline end-to-end before wiring real presenters.
# Output video will obviously not look like the caddie until you set this.
# D_ID_KEVIN_PRESENTER_ID=
# D_ID_SERENA_PRESENTER_ID=
# D_ID_TANK_PRESENTER_ID=
# D_ID_HARRY_PRESENTER_ID=

# ── OPTIONAL voice routing ───────────────────────────────────────────
# ElevenLabs voice id per caddie. When set, D-ID routes TTS through
# ElevenLabs with this voice id so the pre-rendered video matches the
# in-app /api/voice TTS voice. When unset, D-ID uses Microsoft Azure
# en-US-GuyNeural as the default voice.
# D_ID_KEVIN_VOICE_ID=1fz2mW1imKTf5Ryjk5su
# D_ID_SERENA_VOICE_ID=RGb96Dcl0k5eVje8EBch
# D_ID_TANK_VOICE_ID=gQOVuaEi4cxS2vkZAK3A
# D_ID_HARRY_VOICE_ID=5Jfxy1x2Df4No3LQBZXE
